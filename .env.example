# =====================================================================
# PontoSnap — variáveis de ambiente
# Copie para .env (local) ou cadastre no Railway (produção).
# NUNCA versione o .env de verdade.
# =====================================================================

# --- Banco ---------------------------------------------------------
# ATENÇÃO: use o role RESTRITO da aplicação (ponto_app), NÃO o admin.
# Superusuário IGNORA a Row-Level Security e um cliente enxerga o outro.
# Veja packages/db/scripts/setup-role.sql
DATABASE_URL=postgresql://ponto_app:SENHA@host:5432/railway

# URL do ADMIN — usada SÓ para aplicar migrations (preDeployCommand).
# No Railway: DATABASE_URL_ADMIN=${{Postgres.DATABASE_URL}}
DATABASE_URL_ADMIN=postgresql://postgres:SENHA@host:5432/railway

# --- Segurança -----------------------------------------------------
# Chave AES-256 para cifrar o certificado .pfx e sua senha (32 bytes em base64)
# Gere com: openssl rand -base64 32
APP_CRYPTO_KEY=

# Segredos do JWT (gere valores longos e distintos)
# Gere com: openssl rand -hex 32
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Domínios do front autorizados (separados por vírgula).
# Se o front chama a API via rewrite do Vercel (mesma origem), pode deixar vazio.
CORS_ORIGINS=https://app.seudominio.com.br

# --- Identificação da plataforma (vai nos arquivos AFD/AEJ) ---------
# Número do registro INPI do software (único, é da plataforma)
PLATAFORMA_INPI=BR512024001234-5
# CNPJ do desenvolvedor/plataforma (só dígitos)
PLATAFORMA_DOC_DEV=98765432000188
# 1 = CNPJ, 2 = CPF
PLATAFORMA_TIPO_ID_DEV=1
PLATAFORMA_RAZAO=Tutts Tecnologia LTDA
PLATAFORMA_NOME=PontoSnap
PLATAFORMA_VERSAO=1.0.0
PLATAFORMA_EMAIL=contato@seudominio.com.br

# --- Runtime -------------------------------------------------------
PORT=3000
# Processador de jobs em segundo plano. Ligado por padrão.
# Use "off" para desligar (ex.: em réplicas extras da API — veja o DEPLOY.md).
JOBS_LOOP=on

# --- Bootstrap do primeiro MASTER (só na primeira execução) ---------
# Usado por: pnpm --filter @ponto/api exec tsx scripts/criar-master.ts
MASTER_EMAIL=voce@seudominio.com.br
MASTER_SENHA=
